# ==============================================
# A2A Agent Configuration
# ==============================================

# Agent A Configuration
AGENT_A_HOST=127.0.0.1
AGENT_A_PORT=8001
AGENT_A_URL=http://127.0.0.1:8001

# Agent B Configuration  
AGENT_B_HOST=127.0.0.1
AGENT_B_PORT=8002
AGENT_B_URL=http://127.0.0.1:8002

# ==============================================
# Gravitee Gateway Configuration (REQUIRED)
# ==============================================
GRAVITEE_BASE_URL=https://your-gravitee-gateway.com/llm
GRAVITEE_API_KEY=your-api-key-here
GRAVITEE_API_PLATFORM_KEY=your-platform-key-here

# LLM Model (optional)
LLM_MODEL=demo-openai:gpt-4.1

# ==============================================
# Security Configuration
# ==============================================
# CORS Origins (comma-separated, or * for all - NOT recommended for production)
# Example: CORS_ORIGINS=https://app.example.com,https://admin.example.com
CORS_ORIGINS=*

# ==============================================
# MCP Configuration (optional)
# ==============================================
MCP_SERVER_URL=https://your-mcp-server.com/mcp
MCP_API_KEY=your-mcp-api-key
